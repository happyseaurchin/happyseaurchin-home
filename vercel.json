{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "redirects": [
    { "source": "/deeper", "destination": "/touch", "permanent": false },
    { "source": "/deeper.md", "destination": "/touch.md", "permanent": false },
    { "source": "/deeper.html", "destination": "/touch.html", "permanent": false },
    { "source": "/virtual-ai-agents/v2", "destination": "/virtual-ai-agents", "permanent": true },
    { "source": "/mindflow/zand-editor", "destination": "/mindflow/biome-editor/", "permanent": true },
    { "source": "/mindflow/zand-editor/:path(.*)", "destination": "/mindflow/biome-editor/:path", "permanent": true },
    { "source": "/mindflow/zand-filmstrip", "destination": "/mindflow/biome-filmstrip/", "permanent": true },
    { "source": "/mindflow/zand-filmstrip/:path(.*)", "destination": "/mindflow/biome-filmstrip/:path", "permanent": true },
    { "source": "/mindflow/zand.js", "destination": "/mindflow/biome.js", "permanent": true }
  ]
}
